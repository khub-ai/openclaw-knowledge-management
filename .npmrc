# Peer dependencies (e.g. `openclaw`) are provided by the host workspace at
# runtime. Don't auto-install them during development — the openclaw package
# on npm pulls in native binaries that require Node ≥20.
auto-install-peers=false

# Install platform-specific native binaries for all supported platforms so
# that the same node_modules directory works whether you are on Windows,
# Linux (including WSL), or macOS (Intel or Apple Silicon).
# Without this, installing on Windows and then running from WSL (or vice
# versa) fails because packages like esbuild ship OS-specific binaries.
supportedArchitectures.os[]=win32
supportedArchitectures.os[]=linux
supportedArchitectures.os[]=darwin
supportedArchitectures.cpu[]=x64
supportedArchitectures.cpu[]=arm64
