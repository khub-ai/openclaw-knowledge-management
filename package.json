{
  "name": "openclaw-knowledge-management",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start":      "pnpm --filter @khub-ai/playground start",
    "dev":        "pnpm --filter @khub-ai/playground dev",
    "test":       "pnpm --filter @khub-ai/computer-assistant test",
    "test:watch": "pnpm --filter @khub-ai/computer-assistant test:watch",
    "benchmark":  "pnpm --filter @khub-ai/computer-assistant benchmark"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": ["win32", "linux", "darwin"],
      "cpu": ["x64", "arm64"]
    }
  }
}
